    ret
@_rdp_check_timeout
    ustack A $DATASTACK_PTR
    sto A $_conn
    call @TIME.uptime
    ldi A 9
    stack A $DATASTACK_PTR
    ldm A $_conn
    stack A $DATASTACK_PTR
