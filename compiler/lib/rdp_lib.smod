:_rdp_get_buffer_if_else_0
    ldm A $_rdp_packet_pool
    stack A $DATASTACK_PTR
    call @DEQUE.pop
:_rdp_get_buffer_if_end_0
    ret
@_rdp_release_buffer
    call @rt_dup
    stack Z $DATASTACK_PTR
    call @rt_neq
    ustack A $DATASTACK_PTR
    tst A 0
    jmpt :_rdp_release_buffer_if_else_1
    ldm A $_rdp_packet_pool
    stack A $DATASTACK_PTR
