    jmp :_rdp_release_buffer_if_end_1
:_rdp_release_buffer_if_else_1
    call @rt_drop
:_rdp_release_buffer_if_end_1
    ret
@_rdp_send_control_packet
    ustack A $DATASTACK_PTR
    sto A $_msg_type
    ustack A $DATASTACK_PTR
    sto A $_conn
    stack Z $DATASTACK_PTR
    ldm A $_conn
    stack A $DATASTACK_PTR
