@RDP.recv
    ustack A $DATASTACK_PTR
    sto A $_data
    ustack A $DATASTACK_PTR
    sto A $_conn
    ldi A 8
    stack A $DATASTACK_PTR
    ldm A $_conn
    stack A $DATASTACK_PTR
    call @LIST.get
