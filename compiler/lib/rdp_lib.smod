    sto A $_ARR_TEMP_PTR
    ld B Z
    ldm I $_ARR_TEMP_PTR
    stx B $_start_memory_
    ldm A $_msg_type
    stack A $DATASTACK_PTR
    ldm A $_rdp_ctrl_packet
    stack A $DATASTACK_PTR
    call @ARRAY.append
    ldm A $_seq_num
    stack A $DATASTACK_PTR
    ldm A $_rdp_ctrl_packet
    stack A $DATASTACK_PTR
    call @ARRAY.append
    ldm A $_rdp_ctrl_packet
