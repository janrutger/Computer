# 3D wirecube using matrix and matrix operations by de GPU
# using radians in the SIN/COS functions


INCLUDE math_lib
INCLUDE fixed_point_lib
INCLUDE turtle_lib
INCLUDE gpu3_lib

USE std_stern_io
USE std_heap

VALUE cube_vertices 0
VALUE screen_points 0
VALUE mat_vertices 0
VALUE mat_rot_x 0
VALUE mat_rot_y 0
VALUE mat_rot_z 0
VALUE mat_temp 0
VALUE mat_temp_2 0
VALUE mat_final 0
VALUE tdl_1 0
VALUE tdl_2 0
VALUE tdl_3 0

CONST scaleFactor 1000

DEF init_cube {
    ; Initialiseer matrices voor GPU
    8 3 NEW.matrix AS mat_vertices
    3 3 NEW.matrix AS mat_rot_x
    3 3 NEW.matrix AS mat_rot_y
    3 3 NEW.matrix AS mat_rot_z
    8 3 NEW.matrix AS mat_temp
    8 3 NEW.matrix AS mat_temp_2
    8 3 NEW.matrix AS mat_final
    
    ; Gebruik de data-area van de matrix voor de bestaande LIST logic
    mat_vertices 2 + AS cube_vertices
    
    ; Initialiseer TDLs voor chaining
    7 NEW.list AS tdl_1
    7 NEW.list AS tdl_2
    7 NEW.list AS tdl_3

    # Achter vlak (z = 50)
    50 NEGATE FP.from_int 0 cube_vertices LIST.put  ; X Point p4' index=0
    50 NEGATE FP.from_int 1 cube_vertices LIST.put  ; Y index 1
    50 FP.from_int 2 cube_vertices LIST.put         ; Z index 2


    50 FP.from_int 3 cube_vertices LIST.put         ; X Point p5' index=3
    50 NEGATE FP.from_int 4 cube_vertices LIST.put  ; Y index 4
    50 FP.from_int 5 cube_vertices LIST.put         ; Z index 5

    

    50 FP.from_int 6 cube_vertices LIST.put  ; X Point p6' index=6
    50 FP.from_int 7 cube_vertices LIST.put  ; Y index 7
    50 FP.from_int 8 cube_vertices LIST.put  ; Z index 8

    

    50 NEGATE FP.from_int 9 cube_vertices LIST.put     ; X Point p7' index=9
    50 FP.from_int 10 cube_vertices LIST.put            ; Y index 10
    50 FP.from_int 11 cube_vertices LIST.put            ; Z index 11

    # Het voor vlak (z = 50 NEGATE)
    50 NEGATE FP.from_int 12 cube_vertices LIST.put  ; X Point p4 index=12
    50 NEGATE FP.from_int 13 cube_vertices LIST.put  ; Y index 13
    50 NEGATE FP.from_int 14 cube_vertices LIST.put  ; Z index 14

    50 FP.from_int 15 cube_vertices LIST.put            ; X Point p5 index=15
    50 NEGATE FP.from_int 16 cube_vertices LIST.put     ; Y index 16
    50 NEGATE FP.from_int 17 cube_vertices LIST.put     ; Z index 17

    50 FP.from_int 18 cube_vertices LIST.put            ; X Point p6 index=18
    50 FP.from_int 19 cube_vertices LIST.put            ; Y index 19
    50 NEGATE FP.from_int 20 cube_vertices LIST.put     ; Z index 20

    50 NEGATE FP.from_int 21 cube_vertices LIST.put     ; X Point p7 index=21
    50 FP.from_int 22 cube_vertices LIST.put            ; Y index 22
    50 NEGATE FP.from_int 23 cube_vertices LIST.put     ; Z index 23

    CONST p0 0
    CONST p1 3
    CONST p2 6
    CONST p3 9
    CONST p4 12
    CONST p5 15
    CONST p6 18
    CONST p7 21
    
    24 NEW.list AS cube_edges

    # Achter kant
    p0 0 cube_edges LIST.put
    p1 1 cube_edges LIST.put 
    p1 2 cube_edges LIST.put
    p2 3 cube_edges LIST.put
    p2 4 cube_edges LIST.put
    p3 5 cube_edges LIST.put
    p3 6 cube_edges LIST.put
    p0 7 cube_edges LIST.put

    # Het voor vlak
    p4  8 cube_edges LIST.put
    p5  9 cube_edges LIST.put
    p5 10 cube_edges LIST.put
    p6 11 cube_edges LIST.put
    p6 12 cube_edges LIST.put
    p7 13 cube_edges LIST.put
    p7 14 cube_edges LIST.put
    p4 15 cube_edges LIST.put

    # Voor - achter verbindingen
    p0 16 cube_edges LIST.put
    p4 17 cube_edges LIST.put

    p1 18 cube_edges LIST.put
    p5 19 cube_edges LIST.put

    p2 20 cube_edges LIST.put
    p6 21 cube_edges LIST.put

    p3 22 cube_edges LIST.put
    p7 23 cube_edges LIST.put

    

    16 NEW.list AS screen_points

    ; Configureer GPU Chaining
    ; Stap 1: Vertices * RotY -> Temp (Y-as)
    mat_vertices mat_rot_y mat_temp scaleFactor MAT.DOT tdl_2 tdl_1 GPU.tdl
    ; Stap 2: Temp * RotX -> Temp2 (X-as)
    mat_temp mat_rot_x mat_temp_2 scaleFactor MAT.DOT tdl_3 tdl_2 GPU.tdl
    ; Stap 3: Temp2 * RotZ -> Final (Z-as)
    mat_temp_2 mat_rot_z mat_final scaleFactor MAT.DOT 0 tdl_3 GPU.tdl

}

VALUE cube_faces 0

DEF init_faces {
    24 NEW.list AS cube_faces

    # De volgorde van punten bepaalt wat de 'buitenkant' is.
    
    # Voorvlak (Z-negatief zijde)
    p4 0 cube_faces LIST.put  p5 1 cube_faces LIST.put
    p6 2 cube_faces LIST.put  p7 3 cube_faces LIST.put

    # Achtervlak (Z-positief zijde)
    p1 4 cube_faces LIST.put  p0 5 cube_faces LIST.put
    p3 6 cube_faces LIST.put  p2 7 cube_faces LIST.put

    # Rechtervlak
    p5 8 cube_faces LIST.put  p1 9 cube_faces LIST.put
    p2 10 cube_faces LIST.put p6 11 cube_faces LIST.put

    # Linkervlak
    p0 12 cube_faces LIST.put p4 13 cube_faces LIST.put
    p7 14 cube_faces LIST.put p3 15 cube_faces LIST.put

    # Bovenvlak
    p7 16 cube_faces LIST.put p6 17 cube_faces LIST.put
    p2 18 cube_faces LIST.put p3 19 cube_faces LIST.put

    # Ondervlak
    p0 20 cube_faces LIST.put p1 21 cube_faces LIST.put
    p5 22 cube_faces LIST.put p4 23 cube_faces LIST.put
}


DEF draw_solid_cube {
    0 AS f
    WHILE f 6 < DO
        f 4 * AS f_idx
        
        # Haal de scherm-indices van de eerste 3 punten van het vlak
        f_idx     cube_faces LIST.get 3 // 2 * AS s1
        f_idx 1 + cube_faces LIST.get 3 // 2 * AS s2
        f_idx 2 + cube_faces LIST.get 3 // 2 * AS s3
        f_idx 3 + cube_faces LIST.get 3 // 2 * AS s4

        # Haal de X en Y coördinaten van deze punten op
        s1 screen_points LIST.get AS X1  s1 1 + screen_points LIST.get AS Y1
        s2 screen_points LIST.get AS X2  s2 1 + screen_points LIST.get AS Y2
        s3 screen_points LIST.get AS X3  s3 1 + screen_points LIST.get AS Y3
        s4 screen_points LIST.get AS X4  s4 1 + screen_points LIST.get AS Y4

        # Back-face culling berekening (Cross Product van 2 vectoren in 2D)
        # Formule: (X2-X1)*(Y3-Y1) - (Y2-Y1)*(X3-X1)
        X2 X1 - Y3 Y1 - *
        Y2 Y1 - X3 X1 - *
        - AS surface

        # Als surface > 0, dan wijst het vlak naar de camera
        surface 0 > IF
            # Kies een kleur per vlak voor extra effect, of houd het groen
            f 0 == IF red TURTLE.color          END
            f 1 == IF blue TURTLE.color         END
            f 2 == IF green TURTLE.color        END
            f 3 == IF yellow TURTLE.color       END
            f 4 == IF cyan TURTLE.color         END
            f 5 == IF lightBlue TURTLE.color    END

            X1 Y1 X2 Y2 TURTLE.line
            X2 Y2 X3 Y3 TURTLE.line
            X3 Y3 X4 Y4 TURTLE.line
            X4 Y4 X1 Y1 TURTLE.line
            
        END

        f 1 + AS f
    DONE
    TURTLE.flip
}



DEF init_display {
    TURTLE.start
    db_pixel TURTLE.mode

    green TURTLE.color
    IO 2 NEW    ; instead of the missing TURTLE.clear to clear the screen
}


VALUE f_camera_z 0
VALUE f_focus 0


DEF draw_cube {
    0 AS j
    WHILE j 24 < DO
        # Haal de vertex-indices van deze ribbe op uit cube_edges
        j     cube_edges LIST.get AS p1_idx
        j 1 + cube_edges LIST.get AS p2_idx

        # Zoek de bijbehorende 2D punten op in screen_points
        # Voor p1:
        p1_idx 3 // 2 * AS s1_idx  ; Converteer vertex-idx (0,3,6..) naar screen-idx (0,2,4..)
        s1_idx     screen_points LIST.get AS x1
        s1_idx 1 + screen_points LIST.get AS y1

        # Voor p2:
        p2_idx 3 // 2 * AS s2_idx
        s2_idx     screen_points LIST.get AS x2
        s2_idx 1 + screen_points LIST.get AS y2

        j 8 < IF lightRed TURTLE.color 
        ELSE j 15 > IF darkGray TURTLE.color 
        ELSE red TURTLE.color END END
        


        # Teken de lijn naar de UDC
        x1 y1 x2 y2 TURTLE.line

        j 2 + AS j  ; Spring naar het volgende paar (edge)
    DONE
    TURTLE.flip    ; Toon de buffer op het scherm
}

VALUE angle_y 0
VALUE angle_x 0
VALUE angle_z 0

DEF deg_to_rad { ; ( deg_fp -- rad_fp )
    FP.pi FP.mul
    180 FP.from_int FP.div
}

DEF project_and_rotate_3_axes {
    ; 1. Bereken SIN/COS voor alle assen één keer (voor de hele kubus)
    angle_y deg_to_rad AS ry
    angle_x deg_to_rad AS rx
    angle_z deg_to_rad AS rz
    
    ry FP.cos AS cy  ry FP.sin AS sy
    rx FP.cos AS cx  rx FP.sin AS sx
    rz FP.cos AS cz  rz FP.sin AS sz

    ; 2. Vul de rotatie matrices (3x3)
    ; Mat Rot Y: [cy 0 sy, 0 1 0, -sy 0 cy]
    cy 1 1 mat_rot_y MATRIX.put           0  1 2 mat_rot_y MATRIX.put               sy 1 3 mat_rot_y MATRIX.put
    0  2 1 mat_rot_y MATRIX.put           1 FP.from_int 2 2 mat_rot_y MATRIX.put    0  2 3 mat_rot_y MATRIX.put
    sy NEGATE 3 1 mat_rot_y MATRIX.put    0 3 2 mat_rot_y MATRIX.put                cy 3 3 mat_rot_y MATRIX.put

    ; Mat Rot X: [1 0 0, 0 cx sx, 0 -sx cx]
    1 FP.from_int 1 1 mat_rot_x MATRIX.put    0 1 2 mat_rot_x MATRIX.put            0 1 3 mat_rot_x MATRIX.put
    0  2 1 mat_rot_x MATRIX.put               cx 2 2 mat_rot_x MATRIX.put           sx 2 3 mat_rot_x MATRIX.put
    0  3 1 mat_rot_x MATRIX.put               sx NEGATE 3 2 mat_rot_x MATRIX.put    cx 3 3 mat_rot_x MATRIX.put

    ; Mat Rot Z: [cz -sz 0, sz cz 0, 0 0 1]
    cz 1 1 mat_rot_z MATRIX.put               sz NEGATE 1 2 mat_rot_z MATRIX.put    0 1 3 mat_rot_z MATRIX.put
    sz 2 1 mat_rot_z MATRIX.put               cz 2 2 mat_rot_z MATRIX.put           0 2 3 mat_rot_z MATRIX.put
    0  3 1 mat_rot_z MATRIX.put               0  3 2 mat_rot_z MATRIX.put           1 FP.from_int 3 3 mat_rot_z MATRIX.put

    ; 3. Voer GPU operaties uit (Chain tdl_1 -> tdl_2 -> tdl_3)
    tdl_1 GPU.exec DROP

    0 AS i
    WHILE i 8 < DO
        ; 4. Haal resultaten uit mat_final (1-based row index)
        i 1 + AS row
        row 1 mat_final MATRIX.get AS rx_final
        row 2 mat_final MATRIX.get AS ry_final
        row 3 mat_final MATRIX.get AS rz_final

        ; 5. Projectie naar scherm
        rz_final f_camera_z FP.add AS denom
        
        rx_final f_focus FP.mul denom FP.div FP.to_int 320 + AS sx_final
        ry_final f_focus FP.mul denom FP.div FP.to_int 240 + AS sy_final

        ; Bewaar voor de draw_cube functie
        sx_final i 2 *     screen_points LIST.put
        sy_final i 2 * 1 + screen_points LIST.put

        i 1 + AS i
    DONE
}



CONST camera_z 200
CONST focus    250
CONST circle   360



DEF MAIN {
    HEAP.free 
    scaleFactor FP.set_scale

    1 AS running

    init_cube
    init_faces
    init_display

    focus    FP.from_int AS f_focus
    camera_z FP.from_int AS f_camera_z
    circle   FP.from_int AS _circle


    45 FP.from_int AS angle_x
    45 FP.from_int AS angle_y
    45 FP.from_int AS angle_z

    3 FP.from_int AS shiftY
    5 FP.from_int AS shiftX
    7 FP.from_int AS shiftZ
    
    WHILE running DO
        IO 2 NEW
        
        project_and_rotate_3_axes
        # draw_cube
        draw_solid_cube
        
        ; Verhoog hoeken met verschillende snelheden
        angle_y shiftY + _circle % AS angle_y
        angle_x shiftX + _circle % AS angle_x
        angle_z shiftZ + _circle % AS angle_z

        KEYpressed IF
            27 == IF                ; Check for <esc>
                0 AS running
            END
        END
        
        # ; Reset hoeken bij 360
        # angle_y _circle > IF 0 AS angle_y END
        # angle_x _circle > IF 0 AS angle_x END
        # angle_z _circle > IF 0 AS angle_z END
    DONE
}

MAIN