# Sternnet v0.2 Test - Host A
# Sends a message to Host B, then listens for a reply.

INCLUDE socket_lib
USE std_heap
USE std_deque
USE std_stern_io

VALUE my_inbox 0

DEF print_message {
    # ( message_ptr -- )
    # Prints the contents of a received network message envelope.
    AS message_ptr

    "--- Received Message ---\n" PRTstring
    # Get pointer to envelope data (which is at offset 2 of the array)
    VALUE data_ptr 0
    message_ptr 2 + AS data_ptr
    VALUE tmp_ptr 0
    # Print Header Fields
    "  Source ID   : " PRTstring
    *data_ptr PRINT
    "  Dest Port   : " PRTstring
    data_ptr 1 + AS tmp_ptr
    *tmp_ptr PRINT
    "  Source Port : " PRTstring
    data_ptr 2 + AS tmp_ptr
    *tmp_ptr PRINT
    "  Payload Len : " PRTstring
    VALUE message_len 0
    data_ptr 3 + AS tmp_ptr
    *tmp_ptr DUP AS message_len PRINT
    # Print Payload
    "  Payload     : " PRTstring
    VALUE mes_load_ptr 0
    data_ptr 4 + AS mes_load_ptr
    # The payload is not null-terminated. We must add a terminator before printing.
    mes_load_ptr message_len + AS temp_ptr
    0 AS *temp_ptr
    mes_load_ptr PRTstring
    "\n------------------------\n" PRTstring
}

DEF main {
    # 1. Prepare the runtime environment
    HEAP.free
    32 DEQUE.init_pool
    "Starting Network Test Host A...\n" PRTstring
    # 2. Configure network
    \"host-a" 128 SOCKET.init
    # 3. Bind to port 100
    DEQUE.new AS my_inbox
    100 my_inbox SOCKET.bind
    # 4. Send message to host-b on port 200
    STRING message_to_b "Hello from Host A"
    \"host-b" 200 100 &message_to_b SOCKET.snd_text
    IF
        "Host A: Message sent to Host B.\n" PRTstring
    ELSE
        "Host A: Failed to send message to Host B.\n" PRTstring
    END
    # 5. Listen for a message from host B
    64 NEW.array AS received_message
    VALUE read_success 0 
    VALUE retry_count 50

    WHILE retry_count 0 > DO
        received_message my_inbox SOCKET.read AS read_success
        read_success IF
            0 AS retry_count
        ELSE
            retry_count 1 - AS retry_count
            retry_count PRINT
            ASM {
                nop
            }
        END
    DONE

    read_success IF   
        "Host A: Received message from Host B:\n" PRTstring
        received_message print_message
    ELSE
        "Host A: No message received from Host B.\n" PRTstring
    END

    "Host A: Test complete.\n" PRTstring
}

main