#     0 AS i
#     WHILE i 8 < DO
#         # 1. Haal de originele punten op
#         i 3 * AS v_idx
#         v_idx     cube_vertices LIST.get AS vx
#         v_idx 1 + cube_vertices LIST.get AS vy
#         v_idx 2 + cube_vertices LIST.get AS vz

#         # 2. Directe Rotatie (Y-as)
#         # We doen de berekening direct hier om 'rotate_point' functies te besparen
#         angle FP.cos AS ca
#         angle FP.sin AS sa

#         vx ca FP.mul  vz sa FP.mul  FP.sub AS rx   ; de nieuwe X
#         vx sa FP.mul  vz ca FP.mul  FP.add AS rz   ; de nieuwe Z

#         # 3. Directe Projectie naar screen_points
#         rz f_camera_z FP.add AS denom
        
