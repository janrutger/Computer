#         sy i 2 * 1 + screen_points LIST.put

#         i 1 + AS i
#     DONE
# }

VALUE angle_y 0
VALUE angle_x 0

DEF project_and_rotate_2_axes {
    ; 1. Bereken SIN/COS voor beide assen één keer (voor de hele kubus)
    angle_y FP.cos AS cy
    angle_y FP.sin AS sy
    angle_x FP.cos AS cx
    angle_x FP.sin AS sx

    0 AS i
    WHILE i 8 < DO
        ; Haal originele punten
        i 3 * AS v_idx
        v_idx cube_vertices LIST.get AS vx
        v_idx 1 + cube_vertices LIST.get AS vy
        v_idx 2 + cube_vertices LIST.get AS vz

        ; --- STAP A: Rotatie om Y-as ---
        vx cy FP.mul  vz sy FP.mul  FP.sub AS rx
        vx sy FP.mul  vz cy FP.mul  FP.add AS rz_temp

        ; --- STAP B: Rotatie om X-as (we gebruiken rz_temp) ---
        vy cx FP.mul  rz_temp sx FP.mul  FP.sub AS ry
        vy sx FP.mul  rz_temp cx FP.mul  FP.add AS rz

        ; --- STAP C: Projectie naar scherm ---
        rz f_camera_z FP.add AS denom
        
        rx f_focus FP.mul denom FP.div FP.to_int 320 + AS sx_final
        ry f_focus FP.mul denom FP.div FP.to_int 240 + AS sy_final

        sx_final i 2 * screen_points LIST.put
        sy_final i 2 * 1 + screen_points LIST.put

        i 1 + AS i
    DONE
}


# DEF MAIN {
#     HEAP.free 
#     1000 FP.set_scale


#     init_cube
#     init_display

#     project_all    ; Bereken de 2D punten
#     draw_cube      ; Teken de lijnen
# }

DEF MAIN {
    HEAP.free 
    1000 FP.set_scale
    init_cube
    init_display

    focus    FP.from_int AS f_focus
    camera_z FP.from_int AS f_camera_z
    360      FP.from_int AS _circle


    45 FP.from_int AS angle_x
    45 FP.from_int AS angle_y
    
    WHILE 1 DO
        IO 2 NEW
        
        project_and_rotate_2_axes
        draw_cube
        
        ; Verhoog hoeken met verschillende snelheden
        angle_y 30 + AS angle_y
        angle_x 50 + AS angle_x
        
        ; Reset hoeken bij 360
        angle_y _circle > IF 0 AS angle_y END
        angle_x _circle > IF 0 AS angle_x END
    DONE
}

MAIN