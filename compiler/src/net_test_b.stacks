# Sternnet v0.2 Test - Host B
# Listens for a message from Host A, then sends a reply.

INCLUDE socket_lib
USE std_heap
USE std_deque
USE std_stern_io

VALUE my_inbox 0

DEF print_message {
    # ( message_ptr -- )
    # Prints the contents of a received network message envelope.
    AS message_ptr
    "--- Received Message ---\n" PRTstring

    "  Source ID   : " PRTstring
    message_ptr MESSAGE.src PRINT
    "  Dest Port   : " PRTstring
    message_ptr MESSAGE.dest_port PRINT
    "  Source Port : " PRTstring
    message_ptr MESSAGE.src_port PRINT
    "  Payload Len : " PRTstring
    message_ptr MESSAGE.len PRINT
    "  Payload     : " PRTstring
    message_ptr MESSAGE.as_string PRTstring
    "\n------------------------\n" PRTstring
}

DEF main {
    # 1. Prepare the runtime environment
    HEAP.free
    32 DEQUE.init_pool
    STRING hosthello "HELLO"
    "Starting Network Test Host B...\n" PRTstring
    # 2. Configure network
    \"host-b" 128 SOCKET.init
    
    # 3. Bind to port 200
    DEQUE.new AS my_inbox
    200 my_inbox SOCKET.bind


    # 4. Listen for a message from host A
    64 NEW.array AS received_message
    VALUE read_success 0 
    VALUE retry_count 50
    
    WHILE retry_count 0 > DO
        received_message my_inbox SOCKET.read AS read_success
        read_success IF
            0 AS retry_count
        ELSE
            retry_count 1 - AS retry_count
            retry_count PRINT
            ASM {
                nop
            }
        END
    DONE

    read_success IF
        "Host B: Received message from Host A:\n" PRTstring
        received_message print_message

        # 5. Send a reply to host A on port 100
        STRING reply_to_a "Reply from Host B"
        &reply_to_a \"host-a" 100 200 SOCKET.snd_text
        IF
            "Host B: Reply sent to Host A.\n" PRTstring
        ELSE
            "Host B: Failed to send reply to Host A.\n" PRTstring
        END
    ELSE
        "Host B: No message received from Host A.\n" PRTstring
    END
    "Host B: Test complete.\n" PRTstring
}

main