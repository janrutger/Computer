# rdp_test.stacks
# Test program for the Reliable Data Protocol (RDP) library.
# Simulates a loopback connection between two ports (100 and 101) 
# within the same process to verify the handshake logic.

INCLUDE socket_lib
INCLUDE rdp_lib

USE std_stern_io
USE std_deque
USE std_time

# --- Constants & Globals ---
VALUE _inbox_server 0   # Port 100
VALUE _inbox_client 0   # Port 101
VALUE _client_conn 0    # Pointer to the client-side connection record
VALUE _server_conn 0    # Pointer to the server-side connection record (found in dict)
VALUE _test_payload 0   # Array for testing data send
VALUE _has_sent 0       # Flag to send only once
VALUE _cnt 0
VALUE _idx 0
VALUE __ptr 0
VALUE _recv_buf 0       # Buffer to hold received data
VALUE _recv_success 0
VALUE _recv_i 0
VALUE _recv_len 0
VALUE _stress_i 0       # Counter for stress test loop

# Helper to print the state of a connection
DEF print_conn_state {
    AS _conn
    "(2=INIT, 3=OPEN) " PRTstring RDP_STATE _conn LIST.get PRINT
}

DEF print_server_rx_state {
    AS _conn
    "Server RX Next Seq: " PRTstring RDP_SEQ_IN _conn LIST.get PRTnum "\n" PRTstring
}

MACRO Yield {
    ASM {
        nop
    }
}


DEF main {
    "--- RDP Handshake Test ---\n" PRTstring

    # 1. Initialize Network & RDP
    HEAP.free
    32 DEQUE.init_pool
    # TIME.init  ; is done at boottime by the bootfile
    
    # Configure the generic network stack
    \"stern-test" 128 SOCKET.init
    IF
        "Network Initialized.\n" PRTstring
    ELSE
        "Network Init Failed.\n" PRTstring
        HALT
    END

    # Initialize the RDP library
    RDP.init
    "RDP Library Initialized.\n" PRTstring

    # Alloc receive buffer for testing (Capacity 64)
    64 NEW.array AS _recv_buf


    # 2. Setup Sockets (Inbox Deques)
    # Server on Port 100
    DEQUE.new AS _inbox_server
    100 _inbox_server SOCKET.bind
    "Bound Port 100 (Server)\n" PRTstring

    # Client on Port 101
    DEQUE.new AS _inbox_client
    101 _inbox_client SOCKET.bind
    "Bound Port 101 (Client)\n" PRTstring

    # 3. Initiate Connection (Client -> Server)
    # Connect to "stern-test" (self), DestPort 100, SrcPort 101
    # RDP.connect returns (conn_ptr success_flag). We swap them to handle correctly.
    \"stern-test" 100 101 RDP.connect
    SWAP AS _client_conn
    
    IF
        "Client: Connect call success. Sent HELLO.\n" PRTstring
        _client_conn print_conn_state
    ELSE
        DROP # Drop the failed conn_ptr
        "Client: Connect call failed.\n" PRTstring
        HALT
    END

    # Prepare a dummy payload
    10 NEW.array AS _test_payload
    442 negate _test_payload ARRAY.append
    543 _test_payload ARRAY.append
    644 _test_payload ARRAY.append
    745 _test_payload ARRAY.append

    # 4. Event Loop (Process Packets & Stress Test)
    # We assume the handshake takes a few ticks.
    VALUE _loop_count 0
    WHILE _loop_count 500 < DO  # Increased ticks for Flow Control test
        "Tick " PRTstring _loop_count PRTnum
        " " PRTstring
        
        Yield
        # Update Server (Should receive HELLO, send STAT_ACK)
        _inbox_server RDP.update
        # Update Client (Should receive STAT_ACK, switch to OPEN)
        _inbox_client RDP.update

        # Find Server Connection pointer for inspection (only once after handshake)
        _server_conn 0 == IF
            # Iterate through connections to find the one that isn't the client's
            _rdp_conns DICT.count AS _cnt
            0 AS _idx
            WHILE _idx _cnt < DO
                _idx _rdp_conns DICT.item AS __ptr DROP # Get value, drop key
                __ptr _client_conn != IF
                    __ptr AS _server_conn
                    "Server Connection identified.\n" PRTstring
                    _cnt AS _idx # Break loop
                ELSE
                    _idx 1 + AS _idx
                END
            DONE
        ELSE
            _server_conn print_server_rx_state
        END
        
        # TEST RDP.recv: Check if server has data for application
        _server_conn 0 != IF
            # SCENARIO C TEST: Delay reading to force buffer fill (Backpressure)
            # Server starts reading only after tick 30
            _loop_count 30 > IF
                _recv_buf ARRAY.clear
                Yield
                _server_conn _recv_buf RDP.recv AS _recv_success
                _recv_success IF
                    "Server App: Received Data! Payload: " PRTstring
                    
                    _recv_buf ARRAY.len AS _recv_len
                    0 AS _recv_i
                    WHILE _recv_i _recv_len < DO
                        _recv_i _recv_buf ARRAY.get PRTnum
                        ", " PRTstring
                        _recv_i 1 + AS _recv_i
                    DONE
                    "\n" PRTstring
                END
            END
        END


        # Check State
        _client_conn print_conn_state
        VALUE _stress_count 269
        # TEST RDP.send: If OPEN and not yet sent, try sending data
        # This test continues across multiple ticks until all 10 packets are sent.
        _stress_i _stress_count < IF
            RDP_STATE _client_conn LIST.get RDP_STATE_OPEN == IF
                _stress_i 0 == IF
                    "State OPEN. Starting Stress Test (Scenario A)...\n" PRTstring
                END

                # In each tick, try to send as many packets as possible until the
                # buffer is full (RDP.send returns 0) or all 10 are sent.
                1 AS _can_still_send
                WHILE _stress_i _stress_count < _can_still_send * DO
                    # ( conn_ptr data_ptr length -- success )
                    _client_conn _test_payload 4 RDP.send
                    Yield
                    IF
                        "Send " PRTstring _stress_i PRTnum " OK. " PRTstring
                        _stress_i 1 + AS _stress_i
                    ELSE
                        "Send Blocked. Waiting for sync...\n" PRTstring
                        0 AS _can_still_send # Break inner loop for this tick
                    END
                DONE

                _stress_i _stress_count == IF
                    "Stress Test Completed Successfully.\n" PRTstring
                END
            END
        END

        # Print RDP internal status for debugging
        # RDP.print_status

        _loop_count 1 + AS _loop_count
    DONE

    # Print RDP internal status for debugging
    RDP.print_status
}

main