# Sternnet v0.2 Initialization Test
# Verifies the new socket_lib and the SYS_NET_CONFIG syscall.

INCLUDE socket_lib

USE std_heap
USE std_deque
USE std_stern_io

VALUE my_inbox 0
VALUE list_data 0

DEF print_message {
    # ( message_ptr -- )
    # Prints the contents of a received network message envelope.
    AS message_ptr
    "--- Received Message ---\n" PRTstring
    "  Source ID   : " PRTstring
    message_ptr MESSAGE.src PRINT
    "  Dest Port   : " PRTstring
    message_ptr MESSAGE.dest_port PRINT
    "  Source Port : " PRTstring
    message_ptr MESSAGE.src_port PRINT
    "  Payload Len : " PRTstring
    message_ptr MESSAGE.len PRINT
    "  Payload     : " PRTstring
    message_ptr MESSAGE.as_string PRTstring
    "\n------------------------\n" PRTstring
 }

DEF main {
    # 1. Prepare the runtime environment
    HEAP.free
    32 DEQUE.init_pool

    "Starting Network Initialization Test...\n" PRTstring

    # 2. Call the new SOCKET.init function
    # Pass a host_id (hashed string) and a buffer size (e.g., 128 words)
    \"stern-test" 128 SOCKET.init

    # 3. Check the result from the syscall
    IF
        "SUCCESS: SYS_NET_CONFIG returned 1. Network stack is configured.\n" PRTstring

        # 4. Test SYS_NET_BIND
        DEQUE.new AS my_inbox
        100 my_inbox SOCKET.bind
        "INFO: Called SOCKET.bind for port 100.\n" PRTstring
        # "INFO: Use debugger to inspect _port_map in net_core.\n" PRTstring

        # 5. Test SYS_NET_SEND
        # ( num dest_id dest_port src_port -- success )
        # We testen een negatief getal om de teken-afhandeling en cijfer-conversie te verifiëren.
        1234 NEGATE \"stern-test" 100 100 SOCKET.snd_num
        IF
            "INFO: Number sent by host successfully.\n" PRTstring
        ELSE
            "INFO: Number send by host failed.\n" PRTstring
        END


        # 6. Test SYS_NET_RECV - Polling Loop
        # In this simulated environment, the packet sent in step 5 may not be
        # instantly available for reading. We must poll for it.
        64 NEW.array AS message
        VALUE retry_count 50
        VALUE read_success 0 # Will be 1 on success, 0 on timeout

        # Try to read. SOCKET.read returns 1 on success.
        WHILE retry_count 0 > DO
            message my_inbox SOCKET.read AS read_success
            
            read_success IF
                # Success! Force the loop to exit.
                0 AS retry_count
            ELSE
                # No message yet, decrement and continue.
                retry_count 1 - AS retry_count
                ASM {
                    nop
                }
            END
        DONE

        read_success IF
            "INFO: Message read by host successful.\n" PRTstring
            message print_message

            "INFO: Testing MESSAGE.as_num: " PRTstring
            message MESSAGE.as_num PRINT
            "\n" PRTstring
        ELSE
            "INFO: Message read by host failed (timeout).\n" PRTstring
        END

        # --- 7. Test SOCKET.snd_list ---
        "INFO: Starting SOCKET.snd_list test...\n" PRTstring
        
        # Create a heap array
        5 NEW.array AS list_data
        
        # Populate it with "TEST!" (84, 69, 83, 84, 33)
        84 list_data ARRAY.append
        69 list_data ARRAY.append
        83 list_data ARRAY.append
        84 list_data ARRAY.append
        33 list_data ARRAY.append

        # Send it ( list_ptr dest_id dest_port src_port -- success )
        list_data \"stern-test" 100 100 SOCKET.snd_list
        
        IF
            "INFO: List sent successfully.\n" PRTstring
        ELSE
            "INFO: List send failed.\n" PRTstring
        END

        # Receive it
        50 AS retry_count
        0 AS read_success
        
        WHILE retry_count 0 > DO
            message my_inbox SOCKET.read AS read_success
            
            read_success IF
                0 AS retry_count
            ELSE
                retry_count 1 - AS retry_count
                ASM { 
                    nop 
                }
            END
        DONE

        read_success IF
             "INFO: List message received.\n" PRTstring
             message print_message
        ELSE
             "INFO: List message receive timeout.\n" PRTstring
        END

    END
}

main
